import pickle
import tsfel
import pandas as pd
import numpy as np
import warnings

'''This script extracts TSFEL features for all species in the blockade dataset and saves them to a CSV file.'''
with open('/home/rushang_phira/src/data/complete_feature_sets/all_blockades.pkl', 'rb') as f:
    currents_dict = pickle.load(f)

cfg = tsfel.get_features_by_domain()

all_feature_data = []

for key, currents in currents_dict.items():
    feature_list = []
    print("currently extracting for ", key)
    # Process each currents list
    for ts in currents:
        if len(ts) > 20:
        # Extract TSFEL features for the time series
            warnings.simplefilter("ignore", UserWarning) # I wanted to suppress outputs at the time. Left it in here just in case
            features = tsfel.time_series_features_extractor(cfg, ts, verbose=0)
            feature_list.append(features)
    
    feature_df = pd.concat(feature_list, ignore_index=True)

    # Add the label column
    feature_df['label'] = key

    all_feature_data.append(feature_df)

final_feature_df = pd.concat(all_feature_data, ignore_index=True)

final_feature_df.to_csv("/home/rushang_phira/src/data/complete_feature_sets/tsfel.csv", index=False)

