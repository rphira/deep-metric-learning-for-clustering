features_list = []

valid_segments = k8_k12_k16[k8_k12_k16["length"] > 20].copy()

with warnings.catch_warnings():
    warnings.simplefilter("ignore", category=UserWarning)
    
    for _, row in tqdm(valid_segments.iterrows(), total=len(valid_segments), desc="Extracting features"):
        # Extract exact signal segment
        segment = raw_signal[int(row["idxstart"]):int(row["idxend"])]
        
        # Extract features and add metadata
        feats = tsfel.time_series_features_extractor(cfg, segment, verbose=0)
        feats['id'] = row['id']  # Preserve original ID
        feats['_start'] = row['idxstart']  # For validation
        feats['_end'] = row['idxend']     # For validation
        
        features_list.append(feats)

# Combine all features
tsfel_features = pd.concat(features_list, ignore_index=True)

